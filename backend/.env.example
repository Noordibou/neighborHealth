# Copy to .env and edit. The API loads .env from the current working directory (run uvicorn from backend/).

# Must match a real PostgreSQL login. Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
# Special characters in PASSWORD must be URL-encoded (e.g. @ -> %40).
#
# Matches docker-compose.yml in repo root (docker compose up -d):
#   postgresql+asyncpg://neighborhealth:neighborhealth@localhost:5432/neighborhealth
#
# If you see: InvalidPasswordError: password authentication failed for user "neighborhealth"
# then this URL does not match your server. Fix ONE of:
#   1) Create that role (in psql as superuser): CREATE USER neighborhealth WITH PASSWORD 'neighborhealth';
#      CREATE DATABASE neighborhealth OWNER neighborhealth;  \c neighborhealth  CREATE EXTENSION postgis;
#   2) Or point DATABASE_URL at your existing user (often "postgres") and database where PostGIS is enabled.
DATABASE_URL=postgresql+asyncpg://neighborhealth:neighborhealth@localhost:5432/neighborhealth

JWT_SECRET=change-me-in-production
ANTHROPIC_API_KEY=
MAPBOX_TOKEN=
CENSUS_API_KEY=
CDC_API_KEY=
CORS_ORIGINS=http://localhost:3000
